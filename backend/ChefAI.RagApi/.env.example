# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will NEVER be committed.
# Do not put real keys in .env.example (this file is committed).

# OpenRouter — embeddings (https://openrouter.ai/keys)
OPENROUTER_API_KEY=REPLACE_ME

# PostgreSQL — use any non-empty value for local Homebrew trust auth
RAG_DB_PASSWORD=local-dev
